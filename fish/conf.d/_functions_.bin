# Move filenames to lowercase
function hmmm --description 'Convert filenames/directories to lowercase'
  # Usage: hmmm [directory]
  set -l dir "."
  
  if test (count $argv) -gt 0
    set dir "$argv[1]"
  end

  set dir (readlink -f "$dir")
  echo "Converting files/directories in $dir..."

  # Find all files and directories recursively
  for file in (find "$dir" -depth)
    set -l basename (basename "$file")
    set -l dirname (dirname "$file")
    set -l newname (string lower "$basename")

    # Skip if no change needed
    if test "$basename" = "$newname"
      continue
    end

    set -l newpath "$dirname/$newname"

    # Check if the new path already exists
    if test -e "$newpath"
      echo "Skipping: $file (target exists: $newpath)"
      continue
    end

    # Perform the rename
    mv -- "$file" "$newpath"
    echo "Lowercase: $file → $newpath"
  end
end

# Make multiple copies of a file
function dpe
  # Usage: dpe input.txt 3
  # Ensure the function is properly defined and ready to be used.
  set -l usage "dpe: Create multiple copies of a file."
  argparse --help --usage "$usage" i=t

  if not test $argv[1]
    echo "$usage"
    return 1
  end

  set -l ncopies (count $argv)
  set -l input_file "$argv[1]"

  for i in (seq 1 $ncopies)
    cp "$input_file" "i$input_file"
  end
end

# DES3 OpenSSL decrypt a file
function descramble
  # Usage: descramble <input_file> <output_file>
  argparse --help --usage "Usage: descramble <input_file> <output_file>" in:o=i out:o=i

  if not test $argv[1] or not test $argv[2]
    echo "$usage"
    return 1
  end

  set -l input_file "$argv[in]"
  set -l output_file "$argv[out]"

  openssl des3 -d -in "$input_file" -out "$output_file"
end

# DES3 OpenSSL encrypt a file
function scramble
  # Usage: scramble <input_file> <output_file>
  argparse --help --usage "Usage: scramble <input_file> <output_file>" in:o=i out:o=i

  if not test $argv[1] or not test $argv[2]
    echo "$usage"
    return 1
  end

  set -l input_file "$argv[in]"
  set -l output_file "$argv[out]"

  openssl des3 -salt -in "$input_file" -out "$output_file"
end

# Find files with a pattern in the name
function ff
  # Usage: ff <pattern>
  # Find files with the specified pattern in their names.
  set -l usage "ff: Find files with a specific pattern."
  if test (count $argv) -ne 1
    echo "$usage"
    return 1
  end

  find . -type f -iname "*$1*" -ls
end

# Find a file with pattern $1 and execute $2 on it
function fe
  # Usage: fe <pattern> <command>
  # Find files with the specified pattern in their names and execute the given command on each.
  set -l usage "fe: Find files with a pattern and execute a command."
  if test (count $argv) -ne 2
    echo "$usage"
    return 1
  end
  find . -type f -iname "*$1*" -exec "$2" {} \;
end

# Cut last n lines in file, 20 by default
function cuttail
  # Usage: cuttail <input_file> [n_lines=20]
  # Cut the last n lines (default 20) from the specified file.
  set -l usage "cuttail: Cut the last n lines from a file."
  if test (count $argv) -eq 0
    echo "$usage"
    return 1
  end

  if test (count $argv) -eq 1
    set -l nlines 20
  else
    set -l nlines "$2"
  end

  sed -n -e :a -e "1,$nlines!{P;N;D;}; N; ba" "$1"
end

# What desktop am I running?
function wutdt
  # Retrieve XDG_CURRENT_DESKTOP environment variable.
  set -l desktop "$XDG_CURRENT_DESKTOP"

  # Retrieve GDM_SESSION environment variable for GNOME sessions on Wayland.
  set -l gdm_session "$GDM_SESSION"

  echo "Desktop: $desktop"
  echo "Session: $gdm_session"
end

# Swap two filenames around, if they exist
function tradesies
    set -l TMPFILE "tmp.$fish_pid"

    if test (count $argv) -ne 2
        echo "swap: 2 arguments needed"
        return 1
    end

    if not test -e "$argv[1]"
        echo "swap: $argv[1] does not exist"
        return 1
    end

    if not test -e "$argv[2]"
        echo "swap: $argv[2] does not exist"
        return 1
    end

    mv -- "$argv[1]" "$TMPFILE"
    mv -- "$argv[2]" "$argv[1]"
    mv -- "$TMPFILE" "$argv[2]"
end

# Handy Extract Program.
function pfimpf
    if test -f "$1"
        switch (string lower -- (path extension "$1"))
            case '.tar.bz2' '.tbz2'
                tar xvjf "$1"
            case '.tar.gz' '.tgz'
                tar xvzf "$1"
            case '.bz2'
                bunzip2 "$1"
            case '.rar'
                if command -v unrar >/dev/null
                    unrar x "$1"
                else
                    echo "unrar not installed"
                    return 1
                end
            case '.zip'
                unzip "$1"
            case '.Z'
                uncompress "$1"
            case '.tar'
                tar xvf "$1"
            case '.xz'
                unxz "$1"
            case '*'
                echo "Extension not recognized"
                return 1
        end
    else
        echo "File not found: $1"
        return 1
    end
end

# Get PID to kill, from top
function gettoptopid
  # Set -l usage: This function takes an application name as its argument and returns the process ID (PID) of that application.
  set -l usage "gettoptopid <application_name>"

  if not test -z "$argv[1]"
    top -p "$(pgrep -d , "$argv[1]")"
  else
    echo "$usage"
  end
end

function favico
  # Create a 16x16px favicon.ico file
  set -l usage "favico <input_image_path> [<output_path>]"

  if test -z "$argv[1]"
    echo $usage
    return 1
  end

  set -l input_file "$argv[1]"
  set -l output_file "favicon.ico"

  if test -n "$argv[2]"
    set output_file "$argv[2]"
  end

  if command -v magick >/dev/null
    magick convert "$input_file" -resize 16x16 -gravity center -crop 16x16+0+0 \
      -flatten -colors 256 -background transparent "$output_file"
    echo "Created favicon: $output_file"
  else
    echo "Error: ImageMagick not installed"
    return 1
  end
end

# Play random audio files from a directory using ffplay (from ffmpeg)
function toonzes
  # Play random audio files from a directory using ffplay (from ffmpeg)
  set -l usage "toonzes [<directory_path>]"

  if test -z "$argv[1]"
    set dir "."
  else
    set dir "$argv[1]"
  end

  # Find and play random audio files in the specified directory
  for f in (find "$dir" -type f \( -iname "*.mp3" -o -iname "*.flac" -o -iname "*.wav" -o -iname "*.aac" -o -iname "*.mp4" \) | shuf)
    if test -n "$(ffprobe -v error -select_streams a -show_entries stream=codec_name -of default=noprint_wrappers=1 "$f" 2>/dev/null)"
      echo "Playing: $f"
      ffplay -autoexit -nodisp -- "$f" >/dev/null 2>&1
    else
      echo "Skipping: $f (no audio stream found)"
    end
  end
end

